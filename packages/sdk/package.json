{
  "name": "@pome-sh/sdk",
  "version": "0.5.1",
  "description": "Twin engine for Pome digital twins — defineTwin() + serve(): HTTP mounting, bearer auth, trace recorder, MCP dispatch, SQLite-backed state.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./parity": {
      "types": "./dist/parity.d.ts",
      "default": "./dist/parity.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pome-sh/digital-twins.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/pome-sh/digital-twins/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/pome-sh/digital-twins/issues"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.build.json",
    "emit-fidelity": "tsx scripts/emit-fidelity.ts"
  },
  "dependencies": {
    "@pome-sh/shared-types": "0.12.0",
    "hono": "^4.12.31",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "@hono/node-server": "^2.0.8"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.10",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
