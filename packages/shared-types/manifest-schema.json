{
  "$id": "https://pome.sh/schemas/v1/pome.json",
  "title": "Pome agent manifest (pome.json / pome.yaml)",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "agent": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "framework": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "slug"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "twins": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tasks": {
      "type": "string",
      "minLength": 1
    },
    "artifacts_dir": {
      "default": "runs",
      "type": "string",
      "minLength": 1
    },
    "pass_threshold": {
      "default": 100,
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    }
  },
  "required": [
    "agent"
  ]
}
