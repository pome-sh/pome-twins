{
  "name": "@pome-sh/twin-github",
  "version": "0.1.0",
  "description": "Deterministic GitHub-shaped twin for agent testing — REST + MCP, SQLite-backed state.",
  "private": true,
  "type": "module",
  "main": "./dist/src/server.js",
  "bin": {
    "twin-github": "./dist/src/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "FIDELITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/server.ts",
    "seed": "tsx scripts/seed.ts",
    "smoke": "tsx scripts/smoke.ts",
    "validate:mcp": "tsx scripts/validate-mcp.ts",
    "agent:claude": "tsx examples/claude-github-agent.ts",
    "review:harness": "tsx scripts/review-harness.ts",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "capture:fixtures": "tsx scripts/capture-gh-fixtures.ts",
    "fidelity:parity": "tsx scripts/fidelity-parity.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@pome-sh/shared-types": "workspace:*",
    "better-sqlite3": "^12.5.0",
    "hono": "^4.12.27",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/openapi-types": "^27.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "github",
    "twin",
    "test-double",
    "agent-testing",
    "mcp",
    "pome"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pome-sh/pome.git",
    "directory": "packages/twin-github"
  },
  "homepage": "https://github.com/pome-sh/pome/tree/main/packages/twin-github",
  "bugs": {
    "url": "https://github.com/pome-sh/pome/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  }
}
