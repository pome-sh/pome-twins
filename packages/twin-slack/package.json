{
  "name": "@pome-sh/twin-slack",
  "version": "0.1.2",
  "description": "Deterministic Slack Web API twin for agent testing — REST + MCP, SQLite-backed state.",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "default": "./dist/src/server.js"
    },
    "./*": "./dist/src/*.js"
  },
  "bin": {
    "twin-slack": "./dist/src/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "FIDELITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/server.ts",
    "seed": "tsx scripts/seed.ts",
    "smoke": "tsx scripts/smoke.ts",
    "validate:mcp": "tsx scripts/validate-mcp.ts",
    "verify:cloud-token": "tsx scripts/verify-cloud-token.ts",
    "agent:claude": "tsx examples/claude-slack-agent.ts",
    "start": "node dist/src/server.js",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@pome-sh/sdk": "0.3.1",
    "@pome-sh/shared-types": "0.6.0",
    "hono": "^4.12.27",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/web-api": "^7.16.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "slack",
    "twin",
    "test-double",
    "agent-testing",
    "mcp",
    "pome"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pome-sh/pome-twins.git",
    "directory": "packages/twin-slack"
  },
  "homepage": "https://github.com/pome-sh/pome-twins/tree/main/packages/twin-slack",
  "bugs": {
    "url": "https://github.com/pome-sh/pome-twins/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  }
}
