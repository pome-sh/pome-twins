{
  "name": "@pome-sh/twin-gmail",
  "version": "0.1.2",
  "description": "Deterministic Gmail-shaped twin for agent testing — SQLite-backed domain core.",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "default": "./dist/src/server.js"
    },
    "./*": "./dist/src/*.js"
  },
  "bin": {
    "twin-gmail": "./dist/src/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "REFERENCE-DIVERGENCES.md",
    "LIMITS.md",
    "CHANGELOG.md",
    "HOSTED.md",
    "fidelity.inventory.json",
    "fixtures"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/src/server.js",
    "prepack": "npm run build",
    "test": "node --test test/gate0-fixtures.test.mjs && vitest run test/domain.test.ts test/mcp.test.ts test/rest.test.ts test/agent-path.test.ts test/official-client.test.ts test/limits.test.ts test/concurrency.test.ts test/canary-matrix.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fidelity:parity": "tsx scripts/fidelity-parity.ts",
    "preview:drift": "tsx scripts/preview-drift.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@pome-sh/sdk": "0.5.1",
    "hono": "^4.12.31",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@googleapis/gmail": "17.0.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "gmail",
    "twin",
    "test-double",
    "agent-testing",
    "pome",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pome-sh/digital-twins.git",
    "directory": "packages/twin-gmail"
  },
  "homepage": "https://github.com/pome-sh/digital-twins/tree/main/packages/twin-gmail",
  "bugs": {
    "url": "https://github.com/pome-sh/digital-twins/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  }
}
