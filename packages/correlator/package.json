{
  "name": "@pome-sh/correlator",
  "version": "0.1.0",
  "description": "Pure-function correlator: turns a RecorderEvent[] stream (plus optional adapter signals) into Run.lanes + Run.steps for the /runs/:id dashboard.",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "publishConfig": { "access": "public" },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pome-sh/shared-types": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=20"
  }
}
