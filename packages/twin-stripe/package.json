{
  "name": "@pome-sh/twin-stripe",
  "version": "0.2.4",
  "description": "Deterministic test double for Stripe x402 machine payments \u2014 stateful clone agents can drive without burning sandbox quota or real chain gas.",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "default": "./dist/src/server.js"
    },
    "./*": "./dist/src/*.js"
  },
  "bin": {
    "twin-stripe": "./dist/src/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "FIDELITY.md",
    "fidelity.inventory.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/server.ts",
    "seed": "tsx scripts/seed.ts",
    "smoke": "npm run build && tsx scripts/smoke.ts",
    "start": "node dist/src/server.js",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fidelity:parity": "tsx scripts/fidelity-parity.ts"
  },
  "keywords": [
    "stripe",
    "x402",
    "twin",
    "test-double",
    "agent-testing",
    "pome",
    "machine-payments"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pome-sh/pome-twins.git",
    "directory": "packages/twin-stripe"
  },
  "homepage": "https://github.com/pome-sh/pome-twins/tree/main/packages/twin-stripe",
  "bugs": {
    "url": "https://github.com/pome-sh/pome-twins/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@pome-sh/sdk": "0.5.0",
    "@pome-sh/shared-types": "0.11.0",
    "hono": "^4.12.27",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.1.0",
    "stripe": "22.3.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
