{
  "name": "pome-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["packages/*"],
  "packageManager": "npm@11.5.1",
  "scripts": {
    "build": "npm run build -w @pome-sh/shared-types && npm run build -w @pome-sh/sdk && npm run build -w @pome-sh/adapter-claude-sdk && npm run build -w @pome-sh/twin-github && npm run build -w @pome-sh/twin-slack && npm run build -w @pome-sh/twin-stripe",
    "test": "npm run test --workspaces --if-present",
    "test:contract": "node contract/run.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint:no-cloud-imports": "bash scripts/lint-no-cloud-imports.sh",
    "gate:no-eval": "node scripts/no-eval-in-oss.mjs",
    "lint:copy-markers": "node scripts/check-copy-markers.mjs",
    "lint:code-health": "node scripts/lint-code-health.mjs",
    "lint:dead-code": "knip --no-config-hints"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11.5.1"
  },
  "devDependencies": {
    "knip": "^5.66.0"
  },
  "overrides": {
    "hono": "^4.12.27"
  }
}
