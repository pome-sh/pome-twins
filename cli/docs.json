{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Pome",
  "colors": {
    "primary": "#4a6b3a",
    "light": "#4a6b3a",
    "dark": "#7ea766"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/pome-wordmark-color.svg",
    "dark": "/logo/pome-wordmark-on-dark.svg"
  },
  "fonts": {
    "heading": {
      "family": "Source Serif 4",
      "weight": 400
    },
    "body": {
      "family": "Geist"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "customCSS": [
    "/styles/custom.css"
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "getting-started",
              "docs/how-pome-works"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "docs/dashboard",
              "docs/troubleshooting"
            ]
          },
          {
            "group": "Skills",
            "pages": [
              "docs/skills/setup",
              "docs/skills/test-with-pome"
            ]
          },
          {
            "group": "Command Line Interface",
            "pages": [
              "docs/cli/index",
              "docs/cli/run",
              "docs/cli/session",
              "docs/cli/scenarios",
              "docs/cli/compile-seeds",
              "docs/cli/inspect",
              "docs/cli/init"
            ]
          },
          {
            "group": "Twins",
            "pages": [
              "docs/twins/index",
              "docs/twins/github",
              "docs/twins/stripe",
              "docs/twins/slack"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pome-sh",
      "x": "https://x.com/pome_sh"
    }
  }
}
