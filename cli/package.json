{
  "name": "@pome-sh/cli",
  "version": "0.3.0",
  "description": "Digital-twin testing for AI agents — run tasks against resettable local or hosted twins and record tool-call traces for evaluation on pome.sh.",
  "keywords": [
    "ai",
    "agents",
    "agent-testing",
    "digital-twin",
    "llm",
    "evals",
    "claude",
    "anthropic",
    "github",
    "stripe",
    "cli"
  ],
  "homepage": "https://pome.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pome-sh/pome-twins.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/pome-sh/pome-twins/issues"
  },
  "author": "Pome <founders@pome.sh> (https://pome.sh)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "pome": "./dist/src/cli/main.js"
  },
  "files": [
    "dist",
    "examples",
    "scenarios",
    "skills",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/copy-prompts.mjs && node -e \"fs.chmodSync('dist/src/cli/main.js', 0o755)\"",
    "dev": "tsx src/cli/main.ts",
    "pome": "node dist/src/cli/main.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e",
    "gate:no-eval": "node ../scripts/no-eval-in-oss.mjs",
    "gate:no-native": "node ../scripts/no-native-modules.mjs --root .",
    "gate:recorder-overhead": "tsx scripts/recorder-overhead-gate.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.9",
    "@ai-sdk/gateway": "^4.0.13",
    "@ai-sdk/google": "^4.0.9",
    "@ai-sdk/openai": "^4.0.8",
    "@anthropic-ai/sdk": "^0.110.0",
    "@hono/node-server": "^2.0.10",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@pome-sh/sdk": "0.5.1",
    "@pome-sh/shared-types": "0.12.0",
    "@pome-sh/twin-gmail": "0.1.0",
    "@pome-sh/twin-github": "0.2.1",
    "@pome-sh/twin-linear": "0.1.0",
    "@pome-sh/twin-slack": "0.2.1",
    "@pome-sh/twin-stripe": "0.2.4",
    "ai": "^7.0.18",
    "commander": "^15.0.0",
    "hono": "^4.10.7",
    "yaml": "^2.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "bundleDependencies": [
    "@pome-sh/sdk",
    "@pome-sh/shared-types",
    "@pome-sh/twin-gmail",
    "@pome-sh/twin-github",
    "@pome-sh/twin-linear",
    "@pome-sh/twin-slack",
    "@pome-sh/twin-stripe"
  ]
}
